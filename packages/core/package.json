{
  "name": "@llama-crab/core",
  "version": "0.1.6",
  "description": "Core TypeScript contracts and client for llama-crab backends.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "llama.cpp",
    "llama-crab",
    "local-llm",
    "openai",
    "typescript",
    "contracts",
    "gguf",
    "inference"
  ],
  "homepage": "https://llama-crab.nlp.rocks/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DominguesM/llama-crab.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/DominguesM/llama-crab/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
