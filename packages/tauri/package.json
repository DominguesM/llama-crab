{
  "name": "@llama-crab/tauri",
  "version": "0.1.7",
  "description": "Tauri backend adapter for llama-crab.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "llama.cpp",
    "llama-crab",
    "local-llm",
    "openai",
    "typescript",
    "tauri",
    "gguf",
    "inference"
  ],
  "homepage": "https://llama-crab.nlp.rocks/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DominguesM/llama-crab.git",
    "directory": "packages/tauri"
  },
  "bugs": {
    "url": "https://github.com/DominguesM/llama-crab/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm --filter @llama-crab/core build && tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "pnpm --filter @llama-crab/core build && tsc --noEmit",
    "test": "pnpm --filter @llama-crab/core build && vitest run"
  },
  "dependencies": {
    "@llama-crab/core": "workspace:*",
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
