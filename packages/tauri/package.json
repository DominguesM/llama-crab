{
  "name": "@llama-crab/tauri",
  "version": "0.1.300",
  "description": "Tauri backend adapter for llama-crab.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm --filter @llama-crab/core build && tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "pnpm --filter @llama-crab/core build && tsc --noEmit",
    "test": "pnpm --filter @llama-crab/core build && vitest run"
  },
  "dependencies": {
    "@llama-crab/core": "workspace:*",
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
